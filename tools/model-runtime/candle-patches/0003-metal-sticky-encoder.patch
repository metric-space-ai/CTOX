From 053097d3f7bfa97c18e7d788c9cbbf0bdb8ef0f1 Mon Sep 17 00:00:00 2001
From: Michael Welsch <metricspace.ai@gmail.com>
Date: Mon, 20 Apr 2026 20:02:43 +0200
Subject: [PATCH] Metal: sticky compute-encoder reuse + useResource removal

Adds an opt-in (default-on) optimization where successive
`Commands::command_encoder()` calls reuse a single Metal
`MTLComputeCommandEncoder` across dispatches on the same command buffer,
instead of creating a fresh encoder for every kernel launch. The cached
encoder is ended at blit or command-buffer boundaries via
`end_cached_encoder_locked`, and `ComputeCommandEncoder::new_sticky`
wraps it so the user-facing Drop skips `endEncoding` but still releases
the pool semaphore.

Rationale: Gemma 4 E4B Metal decode issues ~3150 kernel launches per
token. Each launch previously cost 2 Metal syscalls (create encoder +
endEncoding on drop). Sticky reuse eliminates ~6300 syscalls/token,
reducing per-kernel wall time overhead on Apple M5.

Disable via `CANDLE_METAL_STICKY_ENCODER=0` if a correctness regression
shows up.

Also includes the prior `useResource` removals from the quantized and
SDPA kernels (5-9% per-kernel wall time win on Apple M5 at the cost of
relying on residency-by-binding).

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 candle-metal-kernels/src/kernels/quantized.rs |  10 +-
 candle-metal-kernels/src/kernels/sdpa.rs      |  12 +-
 candle-metal-kernels/src/metal/commands.rs    | 114 ++++++++++++++++--
 candle-metal-kernels/src/metal/encoder.rs     |  26 +++-
 4 files changed, 133 insertions(+), 29 deletions(-)

diff --git a/candle-metal-kernels/src/kernels/quantized.rs b/candle-metal-kernels/src/kernels/quantized.rs
index d5b70662..9dd1b786 100644
--- a/candle-metal-kernels/src/kernels/quantized.rs
+++ b/candle-metal-kernels/src/kernels/quantized.rs
@@ -167,9 +167,8 @@ pub fn call_quantized_matmul_mv_t(
             r3
         )
     );
-    encoder.use_resource(lhs, MTLResourceUsage::Read);
-    encoder.use_resource(rhs, MTLResourceUsage::Read);
-    encoder.use_resource(dst, MTLResourceUsage::Write);
+    // useResource removed: redundant with direct setBuffer bindings.
+    let _ = (lhs, rhs, dst);
 
     encoder.dispatch_thread_groups(thread_groups_count, threads_per_threadgroup);
     Ok(())
@@ -273,9 +272,8 @@ pub fn call_quantized_matmul_mm_t(
             r3
         )
     );
-    encoder.use_resource(src0, MTLResourceUsage::Read);
-    encoder.use_resource(src1, MTLResourceUsage::Read);
-    encoder.use_resource(dst, MTLResourceUsage::Write);
+    // useResource removed: redundant with direct setBuffer bindings.
+    let _ = (src0, src1, dst);
 
     encoder.set_threadgroup_memory_length(0, 8192);
 
diff --git a/candle-metal-kernels/src/kernels/sdpa.rs b/candle-metal-kernels/src/kernels/sdpa.rs
index 88f3ced7..f2a65880 100644
--- a/candle-metal-kernels/src/kernels/sdpa.rs
+++ b/candle-metal-kernels/src/kernels/sdpa.rs
@@ -227,10 +227,8 @@ pub fn call_sdpa_full(
         height: WM,
         depth: WN,
     };
-    encoder.use_resource(q_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(k_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(v_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(output, MTLResourceUsage::Write);
+    // useResource removed: redundant.
+    let _ = (q_buffer, k_buffer, v_buffer, output);
     encoder.dispatch_thread_groups(grid_dims, group_dims);
 
     Ok(())
@@ -338,10 +336,8 @@ pub fn call_sdpa_vector(
         height: 1,
         depth: 1,
     };
-    encoder.use_resource(q_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(k_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(v_buffer, MTLResourceUsage::Read);
-    encoder.use_resource(output, MTLResourceUsage::Write);
