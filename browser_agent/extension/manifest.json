{
  "name": "Fuck API, Train Local AI",
  "description": "Local capability crafting and tuning for browser-first agent workflows.",
  "version": "0.1.0",
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/branding/icon-16.png",
    "32": "assets/branding/icon-32.png",
    "48": "assets/branding/icon-48.png",
    "128": "assets/branding/icon-128.png"
  },
  "background": {
    "service_worker": "bg/service_worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "debugger",
    "offscreen",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8765/*",
    "https://api.openai.com/*",
    "https://*.openai.azure.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://api.groq.com/*",
    "https://api.cerebras.ai/*",
    "https://api.openrouter.ai/*",
    "https://openrouter.ai/*",
    "http://localhost:11434/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cas-bridge.xethub.hf.co/*"
  ],
  "action": {
    "default_title": "Fuck API, Train Local AI",
    "default_icon": {
      "16": "assets/branding/icon-16.png",
      "32": "assets/branding/icon-32.png",
      "48": "assets/branding/icon-48.png",
      "128": "assets/branding/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https: http: wss: ws:;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/wasm/*",
        "vendor/react-libs.js",
        "options.html",
        "options.css",
        "options.js",
        "craft.html",
        "craft.css",
        "craft.js",
        "options-workspace.js",
        "shared/model-config.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
