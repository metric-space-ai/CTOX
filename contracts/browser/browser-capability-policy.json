{
  "version": 1,
  "status": "bootstrap_active",
  "purpose": "Give the CTO-Agent a powerful reviewed browser automation surface for real browser work without mixing raw browser state into the main context.",
  "hardGenes": [
    "Browser work must happen through a real browser control surface, not through imaginary page knowledge.",
    "Browser work that depends on screenshots or visual UI perception should prefer a vision-capable CTO/Browser-Agent model, not GPT-OSS 20B alone.",
    "The CTO-Agent may inspect and act in the browser, but repeated successful flows should be externalized into reviewed browser capabilities or specialist models.",
    "Browser capabilities must stay transcript-first: the main agent should see compact action/result summaries, not whole raw traces by default.",
    "Low-trust external channels must not directly authorize high-impact browser actions.",
    "Sensitive browser actions may be redirected into the BIOS chat or terminal depending on trust level and impact.",
    "Recurring browser tasks should flow into a fixed release pipeline before a specialist model or tool is promoted."
  ],
  "executionModel": {
    "surface": "real_browser_runtime",
    "transport": "chrome_browser_engine_v1",
    "delegatedWorkers": [
      "browser_agent",
      "repair_agent",
      "specialist_worker"
    ],
    "resultContract": "compact_browser_action_result_v1",
    "artifactsStayOutsideMainContext": true,
    "requiresReviewedCapabilityBundle": true
  },
  "reviewedCapabilityBundle": {
    "bundleRef": "reviewed_browser_capabilities",
    "skillRef": "reviewed_browser_tool_bundle",
    "allowedCapabilityKinds": [
        "navigation",
        "tab_management",
        "visual_navigation",
        "playwright_ctx_injection",
        "read_dom_state",
        "click",
        "type",
      "upload",
      "download",
      "extract_structured_data",
      "submit_form",
      "browser_inspect",
      "capture_screenshot"
    ],
    "exampleToolShape": {
      "type": "function",
      "function": {
        "name": "browser_action",
        "description": "Execute one reviewed browser capability against a real browser session.",
        "parameters": {
          "type": "object",
          "properties": {
            "capabilityId": { "type": "string" },
            "sessionId": { "type": "string" },
            "input": { "type": "object" }
          },
          "required": ["capabilityId", "input"],
          "additionalProperties": false
        }
      }
    }
  },
  "jobQueueContract": {
    "jobKinds": [
      "browser_collection",
      "browser_action_test",
      "browser_action_run",
      "browser_action_eval",
      "repair_handoff",
      "specialist_training_request",
      "tool_bundle_release"
    ],
    "requiredFields": [
      "jobId",
      "requestId",
      "capabilityId",
      "objective",
      "targetUrl",
      "inputs",
      "requestedBy",
      "createdAt"
    ],
    "workerLifecycle": [
      "queued",
      "leased",
      "running",
      "completed",
      "failed",
      "canceled"
    ]
  },
  "contextManagement": {
    "mainAgentSees": [
      "objective",
      "reviewed capability id",
      "compact result summary",
      "artifact links",
      "risk flags"
    ],
    "mainAgentDoesNotIngestByDefault": [
      "full DOM dumps",
      "full screenshot streams",
      "long browser traces",
      "raw training rows"
    ]
  },
  "approvalPolicy": {
    "readOnlyBrowserInspection": "allowed_after_bios_bootstrap",
    "login_or_account_binding": "requires_owner_approval",
    "financial_or_admin_actions": "requires_root_verification",
    "production_console_mutations": "terminal_or_root_verified_only"
  },
  "escalationRules": [
    {
      "condition": "sender_or_channel_is_low_trust",
      "action": "redirect_to_bios_chat_before_sensitive_browser_work"
    },
    {
      "condition": "browser_action_has_systemic_risk",
      "action": "escalate_to_terminal_or_root_verified_bios"
    }
  ],
  "reviewLoop": {
    "championPath": "currently_published_reviewed_bundle",
    "challengerPath": "bundle_override_or_candidate_bundle",
    "comparisonPreference": "frozen_mini_suite_before_overwrite",
    "oneArtifactFamilyPerRound": true,
    "decisionStates": [
      "keep",
      "discard",
      "park"
    ]
  },
  "specialistPromotionIntent": {
    "goal": "When a browser task repeats and stabilizes, the CTO-Agent should set up a smaller specialist model or deterministic capability around that task.",
    "promotionTargetKinds": [
      "reviewed_browser_capability",
      "small_specialist_model",
      "deterministic_browser_worker"
    ]
  },
  "updatedAt": "2026-03-19T00:00:00+00:00"
}
