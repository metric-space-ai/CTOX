#!/usr/bin/expect -f

set timeout 120

if {$argc < 3} {
    puts stderr "usage: cto_remote_password.exp <host> <password> <command>"
    exit 2
}

set host [lindex $argv 0]
set password [lindex $argv 1]
set command [join [lrange $argv 2 end] " "]

spawn ssh -o StrictHostKeyChecking=no $host $command

expect {
    -re {(?i)password: ?} { send -- "$password\r" }
    timeout { puts stderr "ssh password prompt timeout"; exit 1 }
}

expect eof
