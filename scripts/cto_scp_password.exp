#!/usr/bin/expect -f

set timeout 120

if {$argc < 3} {
    puts stderr "usage: cto_scp_password.exp <password> <source> <target>"
    exit 2
}

set password [lindex $argv 0]
set source [lindex $argv 1]
set target [lindex $argv 2]

spawn scp -o StrictHostKeyChecking=no $source $target

expect {
    -re {(?i)password: ?} { send -- "$password\r" }
    timeout { puts stderr "scp password prompt timeout"; exit 1 }
}

expect eof
